[ext_resource type="Script" uid="uid://d0vmpl467m0n0" path="res://scripts/Journal/JournalData.cs" id="1"]

[resource]
script = ExtResource("1")
Name = "Log 1"
Content = "I never realized just how many stars there are in space. They’re hard to see down on Earth, with the smog and the light pollution. @But up here... billions of gleaming beams, death masks for giants that died millennia ago. @Sometimes I wonder if there were billions of Earths orbiting those stars, with billions of Hilts trying to break free. @Was I the only one to get the chance?"
