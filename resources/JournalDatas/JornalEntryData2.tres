[resource]
script = ExtResource("1")
Id = 1
Name = "Log 3: Someone Will Care"
Content = "As a little girl, I would look up and wonder why there were so few stars in the city skies, when my favorite storybooks from the bygone era had so many.@Everything felt so empty, like there was nothing up there watching us, nothing caring about what we did.@ Now, being here, I feel more comfortable than ever. So many suns, so many worlds out there, so many chances that the good we accomplish will matter to someone, somewhere. I feel…at home. "
Category = 0
