[resource]
script = ExtResource("1")
Id = 1
Name = "Engineers, Never Spacewalk Alone!"
Content = "The engineer’s thought-bubble:

I can fix that alone, no biggie!

Next to the image:

ENGINEERS, THINK AGAIN!
@
Never spacewalk alone! All your extravehicular activities must be conducted in teams of two or more and supervised by personnel onboard the station.

TWO IS ONE, ONE IS NONE

In smaller print, at the bottom of the poster:

Consult your Employee Handbook for specific guidelines on extravehicular activities. Failure to comply with these guidelines might nullify your personal insurance and make you liable for damages to company property."
Category = 0
